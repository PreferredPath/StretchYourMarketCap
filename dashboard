  const ec={High:"#475569",Medium:"#f59e0b",Low:"#22c55e"}
  return(
    <div className="card" style={{marginBottom:24}}>
      <h2 style={{fontSize:15,fontWeight:700,color:"var(--ink1)",marginBottom:4}}>Priority Action Plan</h2>
      <p style={{fontSize:12,color:"var(--ink3)",marginBottom:20}}>Ordered by expected visibility impact</p>
      <div style={{display:"flex",flexDirection:"column",gap:10}}>
        {actions.map((a,i)=>(
          <div key={i} style={{display:"flex",alignItems:"center",gap:14,padding:"12px 16px",background:"var(--raised)",borderRadius:10,border:"1px solid var(--border)"}}>
            <div style={{width:28,height:28,borderRadius:"50%",background:"var(--card)",border:"1px solid var(--border)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:11,fontWeight:700,color:"var(--ink3)",flexShrink:0}}>
              {a.p}
            </div>
            <div style={{flex:1,minWidth:0}}>
              <p style={{fontSize:13,fontWeight:500,color:"var(--ink1)"}}>{a.action}</p>
              <div style={{display:"flex",flexWrap:"wrap",gap:6,marginTop:5}}>
                <span style={{fontSize:10,padding:"1px 6px",borderRadius:4,color:ic[a.impact],background:ic[a.impact]+"22"}}>{a.impact} impact</span>
                <span style={{fontSize:10,padding:"1px 6px",borderRadius:4,color:ec[a.effort],background:ec[a.effort]+"22"}}>{a.effort} effort</span>
                <span style={{fontSize:10,color:"var(--ink3)"}}>⏱ {a.timeframe}</span>
              </div>
            </div>
            <span style={{fontSize:14,fontWeight:800,color:"#22c55e",flexShrink:0}}>{a.gain}</span>
          </div>
        ))}
      </div>
      <div style={{marginTop:14,display:"flex",justifyContent:"space-between",alignItems:"center",padding:"12px 16px",background:"rgba(34,197,94,.08)",border:"1px solid rgba(34,197,94,.2)",borderRadius:8}}>
        <span style={{fontSize:13,color:"var(--ink2)"}}>📈 Total potential gain (12 months)</span>
        <span style={{fontSize:20,fontWeight:900,color:"#22c55e"}}>+98 pts</span>
      </div>
    </div>
  )
}

// ─── VIEWS ─────────────────────────────────────────────────────────────────────
function ClientView({data}){
  return(
    <div>
      <Label>Visibility Overview</Label>
      <ScoreHero score={data.score}/>
      <Label>Business Impact</Label>
      <KPICards kpis={data.kpis}/>
      <Label>Platform × Query Presence</Label>
      <HeatmapGrid platforms={data.platforms} heatmap={data.heatmap}/>
      <Label>Competitive Velocity</Label>
      <VelocityChart velocity={data.velocity}/>
      <Label>All Findings</Label>
      <FindingsTable findings={data.findings}/>
    </div>
  )
}

function InternalView({data}){
  return(
    <div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(300px,1fr))",gap:24,marginBottom:24}}>
        <div><Label>Overall Ranking</Label><CompetitorBar data={data.internal.competitorScores}/></div>
        <div><Label>Platform Coverage Map</Label><CompetitorRadar data={data.internal.competitorScores}/></div>
      </div>
      <Label>Score Matrix</Label>
      <ScoreMatrix data={data.internal.competitorScores}/>
      <Label>Action Plan</Label>
      <PriorityActions actions={data.internal.priorityActions}/>
    </div>
  )
}

function Label({children}){
  return <p style={{fontSize:11,color:"var(--ink3)",textTransform:"uppercase",letterSpacing:"0.08em",marginBottom:12}}>{children}</p>
}

// ─── APP ───────────────────────────────────────────────────────────────────────
function App(){
  const [tab,setTab]=useState("client")
  const TABS=[{id:"client",label:"Client Report",icon:"📊"},{id:"internal",label:"Internal Audit",icon:"🔍"}]

  return(
    <div>
      {/* Header */}
      <header className="no-print" style={{position:"sticky",top:0,zIndex:40,background:"rgba(10,11,15,.92)",backdropFilter:"blur(12px)",borderBottom:"1px solid var(--border)"}}>
        <div style={{maxWidth:1280,margin:"0 auto",padding:"0 24px",height:56,display:"flex",alignItems:"center",justifyContent:"space-between"}}>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            <span style={{fontSize:18,fontWeight:800,letterSpacing:"-.02em",color:"var(--ink1)"}}>seen</span>
            <span style={{color:"var(--ink3)"}}>·</span>
            <span style={{fontSize:13,color:"var(--ink2)"}}>AI Visibility Report</span>
          </div>
          <div style={{display:"flex",alignItems:"center",gap:16}}>
            <div style={{textAlign:"right"}}>
              <p style={{fontSize:13,fontWeight:600,color:"var(--ink1)"}}>{DATA.meta.client}</p>
              <p style={{fontSize:11,color:"var(--ink3)"}}>{DATA.meta.subtitle} · {DATA.meta.date}</p>
            </div>
            <button className="btn" onClick={()=>window.print()}
              style={{display:"flex",alignItems:"center",gap:6,padding:"6px 14px",borderRadius:8,background:"var(--raised)",border:"1px solid var(--border)",color:"var(--ink2)",fontSize:13}}>
              ⬇ Export PDF
            </button>
          </div>
        </div>
      </header>

      {/* Tabs */}
      <div className="no-print" style={{borderBottom:"1px solid var(--border)",background:"var(--base)"}}>
        <div style={{maxWidth:1280,margin:"0 auto",padding:"0 24px",display:"flex",gap:4}}>
          {TABS.map(t=>(
            <button key={t.id} className={`tab btn ${tab===t.id?"active":""}`} onClick={()=>setTab(t.id)}>
              <span>{t.icon}</span> {t.label}
            </button>
          ))}
        </div>
      </div>

      {/* Main */}
      <main style={{maxWidth:1280,margin:"0 auto",padding:"32px 24px"}}>
        {tab==="client"?<ClientView data={DATA}/>:<InternalView data={DATA}/>}
      </main>

      {/* Footer */}
      <footer style={{borderTop:"1px solid var(--border)",padding:"20px 24px"}}>
        <div style={{maxWidth:1280,margin:"0 auto",display:"flex",justifyContent:"space-between",fontSize:11,color:"var(--ink3)"}}>
          <span>seen · seenfirst.studio</span>
          <span>{DATA.meta.client} · {DATA.meta.date} · Confidential</span>
        </div>
      </footer>
    </div>
  )
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>)
</script>
</body>
</html>
