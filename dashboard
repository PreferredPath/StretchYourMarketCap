function AnimVal({value,delay}){
  const [disp,setDisp]=useState("0")
  const [go,setGo]=useState(false)
  useEffect(()=>{const t=setTimeout(()=>setGo(true),delay);return()=>clearTimeout(t)},[])
  useEffect(()=>{
    if(!go)return
    const n=parseFloat(String(value).replace(/[^0-9.]/g,""))
    if(isNaN(n)){setDisp(value);return}
    const pre=value.match(/^[^0-9]*/)?.[0]||""
    const suf=value.match(/[^0-9.]+$/)?.[0]||""
    const dur=1000,start=performance.now()
    const tick=now=>{
      const p=Math.min((now-start)/dur,1),e=1-Math.pow(1-p,3)
      const cur=e*n
      const fmt=Number.isInteger(n)?Math.round(cur).toLocaleString():cur.toFixed(1)
      setDisp(`${pre}${fmt}${suf}`)
      if(p<1)requestAnimationFrame(tick)
    }
    requestAnimationFrame(tick)
  },[go])
  return <span>{disp}</span>
}

