// ─── FINDINGS TABLE ────────────────────────────────────────────────────────────
function FindingsTable({findings}){
  const [q,setQ]=useState("")
  const [plat,setPlat]=useState("All")
  const [stat,setStat]=useState("All")
  const [sort,setSort]=useState({k:"score",d:"asc"})
  const [page,setPage]=useState(0)
  const PER=10

  const platforms=["All",...[...new Set(findings.map(f=>f.platform))]]

  const rows=useMemo(()=>{
    let r=findings
    if(q)r=r.filter(x=>[x.platform,x.query,x.issue,x.recommendation].join(" ").toLowerCase().includes(q.toLowerCase()))
    if(plat!=="All")r=r.filter(x=>x.platform===plat)
    if(stat!=="All")r=r.filter(x=>x.status===stat)
    return [...r].sort((a,b)=>{
      const av=a[sort.k]??"",bv=b[sort.k]??""
      return av<bv?(sort.d==="asc"?-1:1):av>bv?(sort.d==="asc"?1:-1):0
    })
  },[findings,q,plat,stat,sort])

  const pages=Math.ceil(rows.length/PER)
  const vis=rows.slice(page*PER,(page+1)*PER)
  const handleSort=k=>{setSort(prev=>({k,d:prev.k===k&&prev.d==="asc"?"desc":"asc"}));setPage(0)}
  const SortArrow=({k})=>sort.k===k?<span style={{color:"var(--blue)",marginLeft:2}}>{sort.d==="asc"?"▲":"▼"}</span>:<span style={{color:"var(--ink3)",marginLeft:2,opacity:.4}}>⇅</span>

  return(
    <div className="card" style={{marginBottom:24}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <div>
          <h2 style={{fontSize:15,fontWeight:700,color:"var(--ink1)"}}>Detailed Findings</h2>
          <p style={{fontSize:12,color:"var(--ink3)",marginTop:2}}>{rows.length} results</p>
        </div>
      </div>
      {/* Filters */}
      <div style={{display:"flex",flexWrap:"wrap",gap:10,marginBottom:16}}>
        <div style={{position:"relative",flex:"1",minWidth:180}}>
          <span style={{position:"absolute",left:10,top:"50%",transform:"translateY(-50%)",color:"var(--ink3)",fontSize:12}}>🔍</span>
          <input value={q} onChange={e=>{setQ(e.target.value);setPage(0)}} placeholder="Search findings…" style={{paddingLeft:30,width:"100%"}}/>
        </div>
        <select value={plat} onChange={e=>{setPlat(e.target.value);setPage(0)}}>
          {platforms.map(p=><option key={p}>{p}</option>)}
        </select>
        <div style={{display:"flex",borderRadius:8,border:"1px solid var(--border)",overflow:"hidden"}}>
          {["All","found","partial","notFound"].map(s=>(
            <button key={s} className="btn" onClick={()=>{setStat(s);setPage(0)}}
              style={{padding:"8px 12px",fontSize:11,background:stat===s?"var(--raised)":"transparent",color:stat===s?"var(--ink1)":"var(--ink3)",fontWeight:stat===s?"600":"400"}}>
              {s==="notFound"?"Not Found":s==="found"?"Found":s==="partial"?"Partial":"All"}
            </button>
          ))}
        </div>
      </div>
      <div className="table-wrap">
        <table>
          <thead>
            <tr>
              {[["platform","Platform"],["query","Query"],["status","Status"],["score","Score"],["issue","Issue"],["recommendation","Recommendation"]].map(([k,l])=>(
                <th key={k} onClick={()=>handleSort(k)}>{l}<SortArrow k={k}/></th>
              ))}
            </tr>
          </thead>
          <tbody>
            {vis.length===0&&<tr><td colSpan={6} style={{textAlign:"center",color:"var(--ink3)",padding:32}}>No results match your filters</td></tr>}
            {vis.map((r,i)=>{
              const st=STATUS[r.status]||STATUS.notFound
              return(
                <tr key={i}>
                  <td style={{color:"var(--ink1)",fontWeight:500,whiteSpace:"nowrap"}}>{r.platform}</td>
                  <td style={{color:"var(--ink2)",maxWidth:160}}><span style={{display:"block",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.query}</span></td>
                  <td><span className="pill" style={{color:st.color,borderColor:st.border,background:st.bg}}>{st.label}</span></td>
                  <td>
                    <div style={{display:"flex",alignItems:"center",gap:6}}>
                      <div style={{width:52,height:5,background:"var(--raised)",borderRadius:999,overflow:"hidden"}}>
                        <div style={{width:`${r.score}%`,height:"100%",background:r.score>=70?"#22c55e":r.score>=30?"#f59e0b":"#ef4444",borderRadius:999}}/>
                      </div>
                      <span style={{color:"var(--ink3)",fontSize:11}}>{r.score}</span>
                    </div>
                  </td>
                  <td style={{color:"var(--ink3)",maxWidth:140}}><span style={{display:"block",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.issue}</span></td>
                  <td style={{color:"var(--ink2)",maxWidth:220}}><span style={{display:"block",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.recommendation}</span></td>
                </tr>
              )
            })}
          </tbody>
        </table>
      </div>
      {pages>1&&(
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginTop:12}}>
          <span style={{fontSize:11,color:"var(--ink3)"}}>{page*PER+1}–{Math.min((page+1)*PER,rows.length)} of {rows.length}</span>
          <div style={{display:"flex",gap:4}}>
            {Array.from({length:pages},(_,i)=>(
              <button key={i} className="btn" onClick={()=>setPage(i)}
                style={{width:28,height:28,borderRadius:6,background:page===i?"var(--blue)":"var(--raised)",color:page===i?"white":"var(--ink3)",fontSize:11,border:"1px solid var(--border)"}}>
                {i+1}
              </button>
            ))}
          </div>
        </div>
      )}
    </div>
  )
}

